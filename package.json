{
  "name": "mcp-skill-cards",
  "version": "0.0.0",
  "private": true,
  "description": "Demo monorepo for portable MCP skill cards (Wassette + MCP Apps)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "bundle": "turbo run bundle",
    "push": "turbo run push",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
