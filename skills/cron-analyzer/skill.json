{
  "name": "cron-analyzer",
  "version": "0.1.0",
  "component": "component.wasm",
  "permissions": {
    "fs": [],
    "net": [],
    "env": []
  },
  "tools": [
    {
      "export": "skills:cron-analyzer/analyzer.analyze",
      "name": "analyze",
      "description": "Parse a cron expression and return upcoming run times",
      "parameterOrder": ["expression", "count", "timezone"],
      "inputSchema": {
        "type": "object",
        "required": ["expression", "count", "timezone"],
        "properties": {
          "expression": { "type": "string", "description": "Cron expression, e.g. '0 9 * * 1-5'" },
          "count": { "type": "integer", "minimum": 1, "maximum": 50, "description": "Number of upcoming runs to return" },
          "timezone": { "type": "string", "description": "IANA timezone, e.g. 'America/New_York'" }
        }
      },
      "_meta": {
        "ui": { "resourceUri": "ui://cron-analyzer/main" }
      }
    }
  ],
  "resources": [
    {
      "uri": "ui://cron-analyzer/main",
      "file": "ui/index.html",
      "mimeType": "text/html"
    }
  ]
}
